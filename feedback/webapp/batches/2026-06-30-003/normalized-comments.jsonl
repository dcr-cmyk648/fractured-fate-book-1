{"anchor_hash": "a42b2b210b3e800282ac49bc13fbf6300a45a19c9523cd8bf4842dd5d5cefa06", "app_version": "review-interface-v0-sync-16", "approximate_scroll_percent": "29", "chapter_id": "d1-ch-42", "chapter_title": "Chapter 42", "comment_text": "Drosin should be established as essentially a High Clade magus level - although Archeon relies on a stack and Drosin needs to use tools, that doesn't mean he isn't an extremely dangerous combatant and certainly the most dangerous person Davian has to actually have a full fight with throughout Book 1 (his things with Caius are brief and interrupted, and he doesn't fight Vorren directly himself, just blocks/supports for Maya and Niall). He ultimately will need Kelyra's help to defeat Drosin, even if the fight is somewhat fair overall", "commenter_name": "DustinR", "commenter_role": "unverified", "commenter_role_verified": false, "content_hash": "c62f668570a79ba2f9499fd770257a21aa44038ec42cff6091d393e0241951a0", "created_at": "2026-06-30T21:41:17.150Z", "current_file_path": "outline/alpha-continuation/units/ch42-kelyra-shroud-maya-attrition.md", "current_heading": "Chapter 42 · Working Chapter Shape", "current_layer": "next_draft_outline", "id": "comment-1782855677149-ovaqog", "import_batch_id": "2026-06-30-003", "imported_at": "2026-06-30T22:09:39+00:00", "importer_version": "webapp-comment-import-v1", "initial_classification": "story-bible-question", "likely_target_id": "d1-ch-42", "likely_target_type": "chapter", "normalized_id": "wc-c62f668570a79ba2", "processing_status": "imported", "reader_id": null, "repo_branch": "main", "repo_commit": "e6e915560bc19f341cf12f2f689eb6d52ce4efa7", "reviewer_session_id": "session-c8d2dc44-e2bf-41fb-b140-abbee704436b", "scratchpad_type": null, "selected_text": null, "source_export_file": "fractured-fate-comments-sheet-sync-20260630-2209.json", "source_line_end": "88", "source_line_start": "44", "status": "inbox", "view_mode": "book-reader"}
