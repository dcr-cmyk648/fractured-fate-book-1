{"anchor_hash": "f7b87ef1578535771ca8188fba48538537137a529adf931b765b1cd22d2fa50f", "app_version": "review-interface-v0", "approximate_scroll_percent": 59, "chapter_id": null, "chapter_title": null, "comment_text": "The zero digit wouldn’t be a shortened strike-line because that would make for instance 2 and 12 identical. So it is either a lengthened line with no mark, or a small notch to indicate that the line was lengthened intentionally to show a zero-value in that segment.", "commenter_name": "Dustin", "content_hash": "fc41f4e7052039ba0dc12422251134704ab20f53bde09e9e4cb4caf855904e79", "created_at": "2026-06-28T02:30:27.676Z", "current_file_path": "bible/cultures/culture-number-system-zan-script.md", "current_heading": "Number System / Zän Script", "current_layer": "repository-file", "id": "comment-1782613827676-fbjt5h", "import_batch_id": "2026-06-29-001", "imported_at": "2026-06-29T19:49:35+00:00", "importer_version": "webapp-comment-import-v1", "initial_classification": "story-bible-question", "likely_target_id": "bible/cultures/culture-number-system-zan-script.md", "likely_target_type": "file", "normalized_id": "wc-fc41f4e7052039ba", "processing_status": "duplicate", "repo_branch": "main", "repo_commit": "c213489d3efba31aafa0287e50f83b8e94f030b5", "reviewer_session_id": "session-432bfb71-a607-43b9-bd28-0a47756c139f", "scratchpad_type": null, "selected_text": "", "source_export_file": "fractured-fate-comments-dustinr-20260629-1416-from-drive.json", "source_line_end": null, "source_line_start": null, "status": "inbox", "view_mode": "repo-browser"}
